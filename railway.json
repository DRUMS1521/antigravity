{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "comfenalco-backend": {
      "build": {
        "context": "./backend",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "gunicorn app.main:app --workers 2 --worker-class uvicorn.workers.UvicornWorker --bind 0.0.0.0:8000"
      },
      "variables": {
        "DATABASE_URL": {
          "reference": "database_url"
        },
        "SECRET_KEY": {
          "value": "tu-clave-secreta-production-muy-segura"
        },
        "FRONTEND_URL": {
          "value": "https://comfenalco-frontend-production.up.railway.app"
        },
        "ALGORITHM": {
          "value": "HS256"
        },
        "ACCESS_TOKEN_EXPIRE_MINUTES": {
          "value": "480"
        },
        "SMTP_HOST": {
          "value": "smtp.gmail.com"
        },
        "SMTP_PORT": {
          "value": "587"
        }
      }
    },
    "comfenalco-frontend": {
      "build": {
        "context": "./frontend",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "serve -s dist -l 3000"
      }
    }
  }
}
